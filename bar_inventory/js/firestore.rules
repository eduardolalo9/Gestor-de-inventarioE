// firestore.rules — BarInventory Fase 1
// ══════════════════════════════════════════════════════════════════════════════
// PUBLICAR: Firebase Console → Firestore → Rules → Editar → Publicar
//           O via CLI:  firebase deploy --only firestore:rules
//
// ESTRUCTURA DE COLECCIONES:
//
//   /usuarios/{uid}
//     Perfiles de usuario con campo 'role': 'admin' | 'user'
//
//   /inventarioApp/{docId}
//     Documento principal: products[], cart[], auditoriaStatus, auditoriaConteo
//     Protección clave: el array 'products' solo puede modificarlo un admin.
//
//   /inventarioApp/{docId}/stockAreas/{area}
//     Conteo operativo por área. Ambos roles escriben sus conteos.
//
//   /inventarioApp/{docId}/conteoAreas/{area}
//     Conteo de auditoría ciega (transaccional). Ambos roles escriben.
//
//   /inventarioApp/{docId}/conteoPorUsuario/{area}
//     Conteos multiusuario por dispositivo. Ambos roles escriben.
//
//   /inventarioApp/{docId}/ordersChunks/{chunk}
//     Histórico de pedidos (append-only). Solo admin escribe.
//
//   /inventarioApp/{docId}/inventoriesChunks/{chunk}
//     Histórico de inventarios guardados. Solo admin escribe.
//
// LÓGICA DE ROLES:
//   admin → acceso completo de lectura y escritura
//   user  → lectura de todo + escritura de conteos propios
//           NO puede modificar el catálogo de productos ni crear pedidos
//
// NOTA SOBRE RENDIMIENTO:
//   Las funciones isAdmin() e isUser() realizan una llamada a get() para
//   leer el documento de /usuarios/{uid}. Cada llamada a get() dentro de
//   las reglas cuenta como una lectura adicional en Firestore.
//   Esto es aceptable para una app de inventario de baja concurrencia,
//   pero considerar cachear el rol en un Custom Claim de Firebase Auth
//   para proyectos de alta escala (ver sección MEJORAS en comentario final).
// ══════════════════════════════════════════════════════════════════════════════

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════
    //  FUNCIONES HELPER
    // ══════════════════════════════════════════════════════════

    /** Verifica que la request proviene de un usuario autenticado */
    function isAuthenticated() {
      return request.auth != null;
    }

    /** Referencia al documento de perfil del usuario autenticado */
    function userDocRef() {
      return /databases/$(database)/documents/usuarios/$(request.auth.uid);
    }

    /** Verifica que existe el documento de perfil del usuario */
    function userProfileExists() {
      return isAuthenticated() && exists(userDocRef());
    }

    /** Obtiene el rol del usuario desde /usuarios/{uid} */
    function getUserRole() {
      return get(userDocRef()).data.role;
    }

    /**
     * isAdmin() — true si el usuario es administrador.
     * Requiere que exista el documento en /usuarios/{uid} con role == 'admin'.
     */
    function isAdmin() {
      return userProfileExists() && getUserRole() == 'admin';
    }

    /**
     * isUser() — true si el usuario tiene rol 'user' o 'admin'.
     * Cualquier usuario registrado puede leer y contar inventario.
     */
    function isUser() {
      return userProfileExists() && getUserRole() in ['admin', 'user'];
    }

    /**
     * isModifyingField(fieldName) — true si el campo indicado cambió.
     * Usa resource.data.diff() que solo funciona en operaciones update
     * (cuando el documento ya existe). NO usar en create.
     */
    function isModifyingField(fieldName) {
      return request.resource.data.diff(resource.data)
               .affectedKeys()
               .hasAny([fieldName]);
    }

    // ══════════════════════════════════════════════════════════
    //  REGLA 1 — USUARIOS
    //  /usuarios/{uid}
    //  Perfiles de usuario con campo 'role'.
    // ══════════════════════════════════════════════════════════
    match /usuarios/{uid} {

      // Leer el propio perfil o admin puede leer cualquiera
      allow read: if request.auth.uid == uid || isAdmin();

      /**
       * Crear perfil (primer login).
       * Condiciones estrictas para evitar auto-elevación de privilegios:
       *   • Solo puede crear su propio documento (uid == auth.uid)
       *   • El rol inicial DEBE ser 'user' (no 'admin')
       *   • El UID en el documento debe coincidir con el UID de auth
       *   • El email debe coincidir con el token de Firebase Auth
       */
      allow create: if request.auth.uid == uid
                    && request.resource.data.role == 'user'
                    && request.resource.data.uid  == request.auth.uid
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.createdAt is number
                    && request.resource.data.lastLogin  is number;

      /**
       * Actualizar perfil.
       * Admin puede cambiar cualquier campo (incluyendo 'role').
       * El propio usuario puede actualizar solo:
       *   • displayName (cambiar nombre de visualización)
       *   • lastLogin   (actualizado automáticamente al iniciar sesión)
       * El propio usuario NO puede cambiar: role, uid, email.
       */
      allow update: if isAdmin()
                    || (request.auth.uid == uid
                        && !request.resource.data.diff(resource.data)
                              .affectedKeys()
                              .hasAny(['role', 'uid', 'email']));

      // Solo admin puede eliminar perfiles
      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════
    //  REGLA 2 — DOCUMENTO PRINCIPAL DE INVENTARIO
    //  /inventarioApp/{docId}
    //
    //  Campo crítico: 'products' (catálogo de productos).
    //  Solo admin puede modificarlo.
    //  Los usuarios pueden actualizar campos operativos:
    //    auditoriaStatus, auditoriaConteo, cart, activeTab, selectedArea
    // ══════════════════════════════════════════════════════════
    match /inventarioApp/{docId} {

      // Cualquier usuario autenticado puede leer el inventario completo
      allow read: if isUser();

      /**
       * Crear el documento principal.
       * Solo admin puede crear (el documento contiene el catálogo de productos).
       */
      allow create: if isAdmin();

      /**
       * Actualizar el documento principal.
       *   Admin: acceso completo (puede modificar products, cart, etc.)
       *   User:  puede actualizar si NO modifica el array 'products'
       *          Puede actualizar: auditoriaStatus, auditoriaConteo,
       *                            cart, activeTab, selectedArea, _lastModified
       */
      allow update: if isAdmin()
                    || (isUser() && !isModifyingField('products'));

      // Solo admin puede eliminar el documento de inventario
      allow delete: if isAdmin();

      // ────────────────────────────────────────────────────────
      //  SUBCOLECCIÓN: stockAreas
      // ────────────────────────────────────────────────────────
      match /stockAreas/{area} {
        allow read:  if isUser();
        allow write: if isUser();
      }

      // ────────────────────────────────────────────────────────
      //  SUBCOLECCIÓN: conteoAreas
      // ────────────────────────────────────────────────────────
      match /conteoAreas/{area} {
        allow read:  if isUser();
        allow write: if isUser();
      }

      // ────────────────────────────────────────────────────────
      //  SUBCOLECCIÓN: conteoPorUsuario
      // ────────────────────────────────────────────────────────
      match /conteoPorUsuario/{area} {
        allow read:  if isUser();
        allow write: if isUser();
      }

      // ────────────────────────────────────────────────────────
      //  SUBCOLECCIÓN: ordersChunks — solo admin escribe
      // ────────────────────────────────────────────────────────
      match /ordersChunks/{chunk} {
        allow read:  if isUser();
        allow write: if isAdmin();
      }

      // ────────────────────────────────────────────────────────
      //  SUBCOLECCIÓN: inventoriesChunks — solo admin escribe
      // ────────────────────────────────────────────────────────
      match /inventoriesChunks/{chunk} {
        allow read:  if isUser();
        allow write: if isAdmin();
      }
    }

    // ══════════════════════════════════════════════════════════
    //  REGLA 3 — NOTIFICACIONES
    //  /notificaciones/{notifId}
    //
    //  Escritura:
    //    Cualquier usuario autenticado puede crear notificaciones
    //    (para enviar solicitudes de ajuste, avisar al admin, etc.)
    //  Lectura:
    //    Admin lee todas. Usuario lee solo las propias o broadcasts.
    //    El filtro por usuarioId se aplica en la capa de aplicación
    //    (notificaciones.js) para mantener las reglas simples.
    //  Actualización (marcar como leída):
    //    El destinatario puede marcar su propia notificación.
    //    Admin puede marcar cualquiera.
    //  Borrado:
    //    Solo admin puede eliminar notificaciones.
    // ══════════════════════════════════════════════════════════
    match /notificaciones/{notifId} {
      allow read:   if isUser();
      allow create: if isUser()
                    && request.resource.data.fecha is number
                    && request.resource.data.tipo is string
                    && request.resource.data.mensaje is string;
      allow update: if isAdmin()
                    || (isUser()
                        && request.resource.data.diff(resource.data)
                              .affectedKeys().hasOnly(['leida']));
      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════
    //  REGLA 4 — AJUSTES DE PRODUCTO
    //  /ajustes/{ajusteId}
    //
    //  Creación: cualquier usuario autenticado puede crear una
    //    solicitud de ajuste (campo 'estado' DEBE ser 'pendiente').
    //  Lectura: admin lee todas; usuario solo las propias.
    //  Actualización: solo admin puede cambiar 'estado', 'procesadoPor'
    //    y 'fechaProcesado' (aprobar / rechazar).
    //  Borrado: solo admin.
    // ══════════════════════════════════════════════════════════
    match /ajustes/{ajusteId} {
      allow read:   if isAdmin()
                    || (isUser()
                        && resource.data.usuarioId == request.auth.uid);
      allow create: if isUser()
                    && request.resource.data.estado == 'pendiente'
                    && request.resource.data.fecha is number
                    && request.resource.data.productoId is string
                    && request.resource.data.campo is string
                    && request.resource.data.valorNuevo is string;
      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data)
                          .affectedKeys()
                          .hasOnly(['estado','procesadoPor','fechaProcesado']);
      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════
    //  REGLA 5 — REPORTES PUBLICADOS
    //  /reportesPublicados/{reporteId}
    //
    //  Solo el admin puede crear y eliminar reportes.
    //  Todos los usuarios autenticados pueden leerlos y descargarlos.
    //  No se permiten actualizaciones (los reportes son inmutables).
    // ══════════════════════════════════════════════════════════
    match /reportesPublicados/{reporteId} {
      allow read:   if isUser();
      allow create: if isAdmin()
                    && request.resource.data.timestamp is number
                    && request.resource.data.titulo is string
                    && request.resource.data.publicadoPor is string;
      allow update: if false;   // los reportes son inmutables
      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════
    //  DENEGACIÓN IMPLÍCITA
    //  Cualquier path no listado arriba es denegado por defecto.
    // ══════════════════════════════════════════════════════════

  }
}

// ══════════════════════════════════════════════════════════════════════════════
// MEJORAS PARA PRODUCCIÓN (FASE 2+):
//
// 1. Custom Claims para evitar get() en cada regla:
//    En lugar de leer /usuarios/{uid} en cada evaluación, configurar
//    Cloud Functions para añadir el rol como Custom Claim al token JWT:
//
//    Admin SDK (functions/index.js):
//    exports.setUserRole = functions.firestore
//      .document('usuarios/{uid}')
//      .onWrite(async (change, context) => {
//        const { uid } = context.params;
//        const role = change.after.data()?.role || 'user';
//        await admin.auth().setCustomUserClaims(uid, { role });
//      });
//
//    Reglas con Custom Claims (sin get(), sin lecturas adicionales):
//    function isAdmin() { return request.auth.token.role == 'admin'; }
//    function isUser()  { return request.auth.token.role in ['admin','user']; }
//
// 2. Validación de schema en campos críticos:
//    allow create para productos puede validar campos obligatorios:
//    && request.resource.data.keys().hasAll(['id', 'name', 'unit', 'group'])
//    && request.resource.data.id is string
//    && request.resource.data.id.size() > 0
//
// 3. Rate limiting por usuario (Fase 3):
//    Limitar escrituras a conteoAreas usando timestamps para evitar
//    flood de escrituras desde un dispositivo comprometido.
// ══════════════════════════════════════════════════════════════════════════════
